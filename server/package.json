{
  "name": "pharmacy-server",
  "version": "1.0.0",
  "description": "Pharmacy Management System - Express API",
  "main": "server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch server.ts",
    "build": "tsc",
    "lint": "eslint . --ext .ts --ignore-path .eslintignore",
    "db:migrate": "tsx config/migrate.ts",
    "db:seed": "tsx config/seed.ts",
    "db:migrate:patient-reports": "tsx config/migratePatientReports.ts",
    "db:migrate:access-requests": "tsx config/migrateAccessRequests.ts",
    "db:migrate:lab-view-requests": "tsx config/migrateLabViewRequests.ts",
    "db:migrate:vitals": "tsx config/migrateVitals.ts"
  },
  "dependencies": {
    "@types/pdf-parse": "^1.1.5",
    "bcryptjs": "^2.4.3",
    "canvas": "^3.2.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.6.205",
    "pg": "^8.12.0",
    "socket.io": "^4.8.3",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "eslint": "^8.57.0",
    "nodemon": "^3.1.4",
    "tsx": "^4.15.0",
    "typescript": "^5.5.2"
  }
}
